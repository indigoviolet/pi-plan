{
	"name": "@indigoviolet/pi-plan",
	"version": "0.4.0",
	"description": "Pi extension for plan mode - read-only exploration and analysis",
	"type": "module",
	"scripts": {
		"check": "biome check --write --error-on-warnings . && tsc --noEmit",
		"prepublishOnly": "npm run check"
	},
	"files": [
		"src/**/*",
		"README.md"
	],
	"keywords": [
		"pi",
		"pi-package",
		"extension",
		"plan-mode",
		"read-only"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"author": "Juan Ibiapina",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/indigoviolet/pi-plan"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@juanibiapina/pi-extension-settings": "^0.4.0"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@mariozechner/pi-coding-agent": "0.65.2",
		"@mariozechner/pi-tui": "0.65.2",
		"@types/node": "^22.10.5",
		"typescript": "^5.9.2"
	}
}
